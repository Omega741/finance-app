# Copy to .env and fill in real values. Never commit .env.

# ---- LLM backend ----
# "ollama" = local, free (default, runs on your GPU via Ollama).
# "anthropic" = paid Anthropic API (higher quality synthesis).
LLM_BACKEND=ollama
LLM_MODEL=qwen3.5:9b
OLLAMA_URL=http://localhost:11434

# Only needed if LLM_BACKEND=anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=

# ---- Alpaca paper trading ----
# Get from alpaca.markets (paper account). Execution is hardcoded paper=True.
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...

# ---- Odysseus pairing (optional) ----
# If set, the daily decision report is pushed to the Odysseus web UI.
# Create a Claude Agent token in Odysseus Settings > Integrations.
ODYSSEUS_URL=http://localhost:7000
ODYSSEUS_API_TOKEN=

# Optional: path for DuckDB journal (default: data/journal.duckdb)
# JOURNAL_DB_PATH=data/journal.duckdb
