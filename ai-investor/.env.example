# Copy to .env and fill in real values. Never commit .env.

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Alpaca paper trading — get from alpaca.markets (paper account)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...

# Optional: path for DuckDB journal (default: data/journal.duckdb)
# JOURNAL_DB_PATH=data/journal.duckdb

# Optional: FRED API key for macro data — fred.stlouisfed.org
# FRED_API_KEY=...
